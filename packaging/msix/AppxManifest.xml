<?xml version="1.0" encoding="utf-8"?>
<Package
    xmlns="http://schemas.microsoft.com/appx/manifest/foundation/windows10"
    xmlns:uap="http://schemas.microsoft.com/appx/manifest/uap/windows10"
    xmlns:rescap="http://schemas.microsoft.com/appx/manifest/foundation/windows10/restrictedcapabilities"
    IgnorableNamespaces="uap rescap">

  <!-- Publisher MUST exactly match the signing certificate's subject.
       build-msix.ps1 creates a self-signed cert with CN=PickMoji for local
       sideloading; replace both with your real publisher identity for the
       Microsoft Store or production distribution. -->
  <Identity
      Name="PickMoji"
      Publisher="CN=PickMoji"
      Version="1.0.0.0"
      ProcessorArchitecture="x64" />

  <Properties>
    <DisplayName>PickMoji</DisplayName>
    <PublisherDisplayName>PickMoji</PublisherDisplayName>
    <Description>A fast, native emoji picker for Windows.</Description>
    <Logo>Assets\StoreLogo.png</Logo>
  </Properties>

  <Dependencies>
    <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersionTested="10.0.22621.0" />
  </Dependencies>

  <Resources>
    <Resource Language="en-us" />
  </Resources>

  <Applications>
    <Application Id="PickMoji" Executable="bin\PickMoji.exe" EntryPoint="Windows.FullTrustApplication">
      <uap:VisualElements
          DisplayName="PickMoji"
          Description="A fast, native emoji picker for Windows."
          BackgroundColor="#17212b"
          Square150x150Logo="Assets\Square150x150Logo.png"
          Square44x44Logo="Assets\Square44x44Logo.png">
        <uap:DefaultTile
            Wide310x150Logo="Assets\Wide310x150Logo.png"
            Square310x310Logo="Assets\Square310x310Logo.png" />
      </uap:VisualElements>
    </Application>
  </Applications>

  <Capabilities>
    <!-- PickMoji is a full-trust Win32 app (global hotkey, SendInput, HKCU). -->
    <rescap:Capability Name="runFullTrust" />
  </Capabilities>
</Package>
